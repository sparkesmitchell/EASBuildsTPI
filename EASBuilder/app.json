{
  "expo": {
    "name": "EAS Build TPI",
    "slug": "easbuildstpi",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sparkesmitchell.easbuilder",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.sparkesmitchell.easbuilder"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store"
    ],
    "scheme": "easbuilder",
    "experiments": {
      "typedRoutes": true
    },
    "owner": "mitchellsparkes",
    "extra": {
      "eas": {
        "projectId": "9bf188bd-1a82-4b0b-b9e4-193819a1b75a"
      }
    }
  }
}
